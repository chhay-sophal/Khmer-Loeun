{
    "manifest_version": 3,
    "name": "ខ្មែរលឿន | Khmer Loeun",
    "short_name": "KhmerLoeun",
    "version": "1.0.0",
    "description": "Convert Sing Khmer (Latin shorthand) to Khmer Unicode instantly.",
    "action": {
        "default_popup": "popup.html",
        "default_title": "ខ្មែរលឿន"
    },
    "permissions": ["storage"],
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["dictionary/*"],
            "matches": ["<all_urls>"]
        }
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "khmer-loeun@example.com",
            "strict_min_version": "109.0"
        }
    }
}